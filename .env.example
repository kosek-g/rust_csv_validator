# ─────────────────────────────────────────────────────────────────────────────
# csv_validator — environment variables
#
# Copy this file to .env and fill in the values for local development.
# NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure Storage ─────────────────────────────────────────────────────────────
# Your Azure Storage account name.
AZURE_STORAGE_ACCOUNT=mystorageaccount

# Primary or secondary Storage Account Key.
# Find it in the Azure Portal → Storage Account → Security + networking → Access keys
AZURE_STORAGE_KEY=your_storage_account_key_here

# ── csv_validator CLI shortcuts ───────────────────────────────────────────────
# These environment variables map to the corresponding CLI flags.
CSV_VALIDATOR_CONTAINER=raw-data
CSV_VALIDATOR_CONFIG=config/example_config.yaml
